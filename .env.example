# Database
DATABASE_URL="postgresql://user:password@localhost:5432/happy_sourcecode?schema=public"

# AI Service - DeepSeek
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# AI Service - 豆包 (Doubao / ByteDance)
DOUBAO_API_KEY=""
DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_MODEL=""

# AI Service - 通义千问 (Tongyi / Alibaba)
TONGYI_API_KEY=""
TONGYI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
TONGYI_MODEL="qwen-plus"

# Default AI provider: deepseek | doubao | tongyi
DEFAULT_AI_PROVIDER="deepseek"

# GitHub (optional, increases API rate limit)
GITHUB_TOKEN=""

# Proxy for GitHub API (required in China mainland, e.g. Clash)
# GITHUB_PROXY="http://127.0.0.1:7890"
